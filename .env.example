# Path to model weights file
MODEL_PATH=models/classifier.pt

# Maximum slices accepted per upload
MAX_SLICES=100

# Set true to enable CUDA inference
USE_GPU=false

# Set true to use a mock model (no PyTorch needed, generates random scores)
USE_MOCK_MODEL=false

# Directory for temporary uploaded/processed files
TEMP_DIR=/tmp/dicom-demo

# Auto-delete temp files after this many seconds
TEMP_RETENTION_SECONDS=3600

# Python logging level
LOG_LEVEL=INFO

# Maximum upload size in megabytes
MAX_UPLOAD_SIZE_MB=500

# Number of slices per inference batch
INFERENCE_BATCH_SIZE=8
